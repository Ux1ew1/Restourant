# Production database. Use the pooled PostgreSQL URL from Supabase/Railway/VPS.
DATABASE_URL="postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Public site URL. Use the final HTTPS domain.
NEXTAUTH_URL="https://example.com"
NEXT_PUBLIC_SITE_URL="https://example.com"

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_SECRET="replace-with-strong-random-secret"

# Optional external image storage.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

NODE_ENV="production"
