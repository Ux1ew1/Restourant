### Zustand-сторы (`.ts` в `src/store/`)

Документировать стор целиком и каждое действие:

```ts
/**
 * Стор корзины товаров.
 *
 * Хранит список позиций, выбранных пользователем для заказа.
 * Данные персистируются в localStorage через zustand/middleware persist.
 * Ключ хранилища: 'cart-storage'.
 */
interface CartStore {
  /** Список позиций в корзине */
  items: CartItem[];

  /**
   * Добавляет товар в корзину.
   * Если товар с таким id и пожеланием уже есть — увеличивает количество.
   *
   * @param product - Товар для добавления
   * @param quantity - Количество (по умолчанию 1)
   * @param wishes - Пожелание клиента к позиции
   */
  addItem: (product: Product, quantity?: number, wishes?: string) => void;

  /** Удаляет позицию из корзины по её уникальному идентификатору */
  removeItem: (cartItemId: string) => void;

  /** Очищает корзину полностью */
  clear: () => void;
}
```

