### TypeScript типы (`src/types/`)

```ts
/**
 * Позиция в корзине пользователя.
 * Отличается от Product дополнительными полями quantity и wishes.
 */
export interface CartItem {
  /** Уникальный идентификатор строки корзины (генерируется на клиенте) */
  cartItemId: string;

  /** Данные товара на момент добавления в корзину */
  product: Product;

  /** Количество единиц данного товара с данным пожеланием */
  quantity: number;

  /** Пожелание клиента к этой позиции (необязательно) */
  wishes?: string;
}
```

