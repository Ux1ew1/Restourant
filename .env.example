# База данных
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_db?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/restaurant_db?schema=public"

# Supabase pooler, replace [YOUR-PASSWORD] before using:
# DATABASE_URL="postgresql://postgres.igostldgdrmuhnzmrzmh:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.igostldgdrmuhnzmrzmh:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Хранение изображений (Cloudinary, если используется)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Окружение
NODE_ENV="development"
